# Voice IT Environment Variables
# ===============================
# Copy this file to .env and customize as needed

# Debug Mode (true/false)
# Enables verbose logging
VOICE_IT_DEBUG=false

# Custom Configuration Path
# Override default config location
# VOICE_IT_CONFIG=/path/to/custom/config.yaml

# Custom Data Directory
# Override default data location
# VOICE_IT_DATA=/path/to/custom/data

# Force Provider
# Override active provider from config
# VOICE_IT_PROVIDER=claude

# Anthropic API Key (optional - for API mode instead of browser)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (optional - for API mode instead of browser)
# OPENAI_API_KEY=sk-...

# Google API Key (optional - for API mode instead of browser)
# GOOGLE_API_KEY=...
